{
  "name": "ecopulse-landing-netlify",
  "version": "2.0.0",
  "private": true,
  "description": "Landing page React + Vite + TypeScript com Netlify Functions para envio de e-mail.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "netlify:dev": "npx netlify-cli dev",
    "function:test": "npx netlify-cli functions:invoke send-email --port 8888 --payload '{\"email\":\"teste@teste.com\",\"message\":\"Ola!\"}'"
  },
  "dependencies": {
    "nodemailer": "^7.0.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-google-recaptcha": "^3.1.0",
    "react-toastify": "^11.0.5"
  },
  "devDependencies": {
    "@netlify/functions": "^5.0.0",
    "@types/node": "^24.10.1",
    "@types/nodemailer": "^7.0.4",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@types/react-google-recaptcha": "^2.1.9",
    "@vitejs/plugin-react": "^6.0.2",
    "netlify-cli": "^26.1.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.16"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
